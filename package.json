  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": ">=3.14"
  },
  "devDependencies": {
    "typescript": "^5",
    "@tamagui/build": "2.0.0-rc.32",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "@types/react-window": "^1.8",
    "react": "^19.2",
    "react-dom": "^19.2",
    "react-native": "^0.83"
  }
}
